<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:bweb="clr-namespace:Microsoft.AspNetCore.Components.WebView.Maui;assembly=Microsoft.AspNetCore.Components.WebView.Maui"
             xmlns:components="clr-namespace:Wardkitten.Mobile.Components"
             x:Class="Wardkitten.Mobile.MainPage"
             BackgroundColor="#0f172a">

    <bweb:BlazorWebView x:Name="blazorWebView" HostPage="wwwroot/index.html">
        <bweb:BlazorWebView.RootComponents>
            <bweb:RootComponent Selector="#app" ComponentType="{x:Type components:Main}" />
        </bweb:BlazorWebView.RootComponents>
    </bweb:BlazorWebView>

</ContentPage>
