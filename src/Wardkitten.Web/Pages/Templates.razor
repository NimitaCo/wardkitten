@page "/templates"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject WardkittenApiClient Api
@inject NavigationManager Nav

<PageTitle>Plantillas · Wardkitten</PageTitle>

<h1 class="h3 mb-3">Empieza con una plantilla</h1>

<div class="row g-3">
    @foreach (var t in _templates)
    {
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <div style="font-size:32px">@t.Emoji</div>
                    <h5 class="card-title">@t.Name</h5>
                    <p class="text-muted small">@t.Description</p>
                    <button class="btn btn-sm btn-primary" @onclick="() => UseAsync(t)" disabled="@_busy">Usar</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<WatchTemplateDto> _templates = new();
    private bool _busy;

    protected override async Task OnInitializedAsync()
    {
        var r = await Api.GetTemplatesAsync();
        if (r.Ok && r.Value is not null) _templates = r.Value;
    }

    private async Task UseAsync(WatchTemplateDto t)
    {
        _busy = true;
        var r = await Api.CreateFromTemplateAsync(t.Id);
        _busy = false;
        if (r.Ok && r.Value is not null) Nav.NavigateTo($"/watches/{r.Value.Id}/edit");
    }
}
