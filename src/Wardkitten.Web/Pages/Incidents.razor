@page "/incidents"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject WardkittenApiClient Api

<PageTitle>Incidentes · Wardkitten</PageTitle>

<h1 class="h3 mb-3">Incidentes</h1>

@if (_incidents.Count == 0)
{
    <p class="text-muted">Sin incidentes. 🎉</p>
}
else
{
    <table class="table">
        <thead><tr><th>Tarea</th><th>Severidad</th><th>Estado</th><th>Abierto</th><th></th></tr></thead>
        <tbody>
            @foreach (var i in _incidents)
            {
                <tr>
                    <td>@i.WatchName</td>
                    <td>@i.Severity</td>
                    <td>@i.State</td>
                    <td>@i.OpenedAtUtc.ToLocalTime().ToString("dd/MM HH:mm")</td>
                    <td class="text-end">
                        @if (i.State == "Open")
                        {
                            <button class="btn btn-sm btn-outline-primary" @onclick="() => AckAsync(i)">Reconocer</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<IncidentDto> _incidents = new();

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        var r = await Api.GetIncidentsAsync();
        if (r.Ok && r.Value is not null) _incidents = r.Value;
    }

    private async Task AckAsync(IncidentDto i) { await Api.AckIncidentAsync(i.Id); await LoadAsync(); }
}
