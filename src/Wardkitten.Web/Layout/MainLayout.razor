@inherits LayoutComponentBase
@inject ClientAuthService Auth
@inject NavigationManager Nav

<div class="d-flex flex-column min-vh-100">
    <nav class="navbar navbar-expand navbar-dark" style="background:linear-gradient(135deg,#1b224e 0%,#243a82 100%)">
        <div class="container">
            <a class="navbar-brand fw-bold d-flex align-items-center gap-2" href="">
                <img src="wardkitten-logo.svg" alt="Wardkitten" height="32" width="32" />
                Wardkitten
            </a>
            <AuthorizeView>
                <Authorized>
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item"><NavLink class="nav-link" href="" Match="NavLinkMatch.All">Panel</NavLink></li>
                        <li class="nav-item"><NavLink class="nav-link" href="watches/new">Nuevo</NavLink></li>
                        <li class="nav-item"><NavLink class="nav-link" href="templates">Plantillas</NavLink></li>
                        <li class="nav-item"><NavLink class="nav-link" href="wallet">Créditos</NavLink></li>
                        <li class="nav-item"><NavLink class="nav-link" href="incidents">Incidentes</NavLink></li>
                        <li class="nav-item"><NavLink class="nav-link" href="status-pages">Status</NavLink></li>
                        <li class="nav-item"><NavLink class="nav-link" href="teams">Equipos</NavLink></li>
                    </ul>
                    <button class="btn btn-sm btn-outline-light" @onclick="LogoutAsync">Salir</button>
                </Authorized>
                <NotAuthorized>
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item"><NavLink class="nav-link" href="login">Entrar</NavLink></li>
                        <li class="nav-item"><NavLink class="nav-link" href="register">Crear cuenta</NavLink></li>
                    </ul>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </nav>

    <main class="container py-4 flex-grow-1">
        @Body
    </main>

    <footer class="text-center text-muted py-3 small">Wardkitten · tu gatito vigilante</footer>
</div>

@code {
    private async Task LogoutAsync()
    {
        await Auth.LogoutAsync();
        Nav.NavigateTo("/login");
    }
}
